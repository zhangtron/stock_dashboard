# 数据库配置 - 本地开发环境
# 注意：生产环境（Zeabur）的数据库配置请在Zeabur项目设置中配置环境变量
DB_HOST=your_mysql_host
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name

# 应用配置
APP_NAME=Stock Dashboard
APP_ENV=development
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000

# ============================================
# Zeabur生产环境配置说明
# ============================================
# 在Zeabur项目设置中添加以下环境变量：
#
# 必需的环境变量：
# - DB_PASSWORD: MySQL数据库密码
#
# 已在zeabur.yaml中配置的环境变量：
# - DB_HOST: mysql.sqlpub.com
# - DB_PORT: 3306
# - DB_USER: chase_zhang
# - DB_NAME: stock_review
# - APP_NAME: Stock Dashboard
# - APP_ENV: production
# - DEBUG: False
#
# 安全提示：
# - 不要在代码仓库中提交真实的数据库密码
# - 使用环境变量管理敏感信息
# - 定期更换数据库密码

