# 数据库配置 - 本地开发环境
# 注意：生产环境（Zeabur）的所有数据库配置都需要在Zeabur项目设置中配置环境变量
DB_HOST=your_mysql_host
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name

# 应用配置
APP_NAME=Stock Dashboard
APP_ENV=development
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000

# ============================================
# Zeabur生产环境配置说明
# ============================================
# ⚠️ 重要：由于仓库是公开的，所有敏感配置都必须在Zeabur项目设置中配置
#
# 在Zeabur项目设置的环境变量部分，需要手动添加以下配置：
#
# ====== 数据库配置（必需） ======
# - DB_HOST: mysql.sqlpub.com
# - DB_PORT: 3306
# - DB_USER: chase_zhang
# - DB_PASSWORD: [您的MySQL密码] ⚠️ 必须在Zeabur中设置
# - DB_NAME: stock_review
#
# ====== 应用配置（已在zeabur.yaml中配置） ======
# - APP_NAME: Stock Dashboard
# - APP_ENV: production
# - DEBUG: False
#
# ====== 配置步骤 ======
# 1. 登录 https://zeabur.com
# 2. 进入 stock-dashboard 项目
# 3. 点击"设置"⚙️图标
# 4. 在"环境变量"部分添加以上所有配置
# 5. 点击"重新部署"
#
# ====== 安全提示 ======
# ✅ 不要在代码仓库中提交真实的数据库密码
# ✅ 使用环境变量管理所有敏感信息
# ✅ 定期更换数据库密码
# ✅ 如果密码泄露，立即修改并在Zeabur中更新
# ✅ .env 文件已在 .gitignore 中，不会被提交

